                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('inventories');",
                  "  pm.expect(body.inventories).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/inventories"
          }
        },
        {
          "name": "GET /api/v1/inventories/:id (id=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Response has inventory object', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('inventory');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
