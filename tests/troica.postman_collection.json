          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "GET /api/v1/orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has orders array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('orders');",
                  "  pm.expect(body.orders).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/orders"
          }
        },
        {
          "name": "POST /api/v1/orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has order with id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('order');",
                  "  pm.expect(body.order).to.have.property('id');",
                  "  pm.expect(body.order.id).to.be.a('number');",
                  "  pm.environment.set('createdOrderId', body.order.id);",
                  "});",
                  "pm.test('Order status is PENDING', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.order.status).to.equal('PENDING');",
                  "});",
                  "pm.test('Order has orderLineItems', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.order.orderLineItems).to.be.an('array');",
                  "  pm.expect(body.order.orderLineItems.length).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"inventoryId\": 1,\n      \"productId\": \"PROD-001\",\n      \"skuCode\": \"SKU-001\",\n      \"price\": 10000,\n      \"quantity\": 2,\n      \"status\": \"PENDING\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/orders"
          }
        },
        {
          "name": "GET /api/v1/orders/:id (created order)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returned order matches created id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('order');",
                  "  pm.expect(body.order.id).to.equal(Number(pm.environment.get('createdOrderId')));",
                  "});",
                  "pm.test('Order has orderLineItems', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.order.orderLineItems).to.be.an('array');",
                  "  pm.expect(body.order.orderLineItems[0].productId).to.equal('PROD-001');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/orders/{{createdOrderId}}"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is UP', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.equal('UP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/healthz"
          }
        }
      ]
    }
  ]
}
